# --- cheatah-gpu ---
# CPM's downloaded bootstrap (the committed cmake/CPM.cmake stays; the versioned copy is fetched).
cmake/CPM_*.cmake
# Clang source-based coverage scratch.
*.profraw
*.profdata
# Compiled shaders (Slang -> SPIR-V is produced on demand by the build/doctor).
*.spv
# Optional, dev-only backend SDKs / vendored refs — fetched ad hoc, NEVER committed, NEVER required.
gpu/vulkan/vendor/
gpu/metal/vendor/
# Generated system-test helper header (qa_gate emits check.purr to a temp dir; guard stray copies).
systests/check.hpp
systests/check.hpp.sha512
# The gpu.* module headers are hand-authored C++ and ARE committed (gpu/**/*.hpp).

# Local Claude Code session settings (not part of the library).
.claude/

# Transient window-test module archive (built + removed by scripts/window_test.sh).
tests/window/libcheatah_window.a
tools/metal-gen/_inputs/
