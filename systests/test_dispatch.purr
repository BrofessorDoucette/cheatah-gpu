# gpu.dispatch — workgroup counts, exercised through the imported library.
import io
import gpu.dispatch as dispatch
import check

io.print("== gpu.dispatch: workgroup counts ==")
let f = 0

# ceil_div: empty, exact multiple, one-over, and the denom==0 guard.
f += check.eq_int("ceil_div 0/64",   dispatch.ceil_div(0, 64),   0)
f += check.eq_int("ceil_div 64/64",  dispatch.ceil_div(64, 64),  1)
f += check.eq_int("ceil_div 65/64",  dispatch.ceil_div(65, 64),  2)
f += check.eq_int("ceil_div 10/0",   dispatch.ceil_div(10, 0),   0)

# group_count_1d composes ceil_div.
f += check.eq_int("groups 1e6@256",  dispatch.group_count_1d(1000000, 256), 3907)
f += check.eq_int("groups 0@256",    dispatch.group_count_1d(0, 256),       0)

# the dispatch must cover every item: groups * local_size >= items.
f += check.is_true("dispatch covers items", dispatch.group_count_1d(1000, 256) * 256 >= 1000)

check.result(f)
