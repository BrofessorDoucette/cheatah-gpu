# test_instance.purr — a PURE-CHEATAH Vulkan system test through the NAMESPACED interface. With
# `import gpu.vulkan as vk`, every Vulkan struct, enum value and handle is reached as `vk.<Name>`
# (no `Vk`/`VK_` prefixes) — `vk.ApplicationInfo`, `vk.STRUCTURE_TYPE_APPLICATION_INFO`,
# `vk.Instance`, `vk.CreateInstance`. The raw `Vk*` / `VK_*` spellings stay available, but only
# inside a cpp{} escape hatch; idiomatic cheatah uses the `vk.` interface. No casts, no cpp{}.
# Run by scripts/vulkan_gate.sh (needs the Vulkan headers + loader, present at release).

import io
import gpu.vulkan as vk

io.print("== gpu.vulkan: instance lifecycle, namespaced cheatah interface ==")

# C++20 designated initializers across multiple lines — the modern Vulkan style, the way a human
# wants to read it — straight from cheatah, through the vk. interface.
let app = vk.ApplicationInfo({
    .sType = vk.STRUCTURE_TYPE_APPLICATION_INFO,
    .apiVersion = vk.API_VERSION_1_3,
})
let ci = vk.InstanceCreateInfo({
    .sType = vk.STRUCTURE_TYPE_INSTANCE_CREATE_INFO,
    .pApplicationInfo = &app,
})

let inst = vk.Instance()
let r = vk.CreateInstance(&ci, 0, &inst)
io.print("  CreateInstance ->", r)

if r != 0 {
    io.print("RESULT: FAIL (CreateInstance returned", r, ")")
} else {
    vk.DestroyInstance(inst, 0)
    io.print("  DestroyInstance -> ok")
    io.print("RESULT: PASS")
}
